{
  "$schema": "../gen/schemas/desktop-schema.json",
  "productName": "Aegis Vault",
  "version": "0.1.0",
  "identifier": "com.aegisvault.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aegis Vault",
        "width": 1540,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "maximized": false,
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "shortDescription": "Plataforma premium de seguridad de archivos para escritorio.",
    "longDescription": "Aplicación de seguridad de archivos y carpetas para escritorio, reconstruida con Tauri 2, React y Rust con arquitectura modular, auditoría local y contenedor cifrado.",
    "windows": {
      "digestAlgorithm": "sha256",
      "wix": {
        "language": "es-ES"
      }
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
